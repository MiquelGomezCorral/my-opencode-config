{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "{env:HOME}/.local/share/my-opencode-config/deps/opencode-quota/dist/index.js",
    "opencode-queue@0.11.2",
    "{env:HOME}/.config/opencode/plugins/ponytail/.opencode/plugins/ponytail.mjs",
    "{env:HOME}/.config/opencode/plugins/vault-context/vault-context.js"
  ],
  "model": "openai/gpt-5.6-terra",
  "small_model": "openai/gpt-5.5",
  "instructions": [
    "Always respond in English unless the user explicitly asks for another language, even if code, markdown, or skill instructions use a different language.",
    "~/.config/opencode/security-rules.md",
    "~/.config/opencode/surgical-rules.md",
    "Always load the ponytail skill before writing or modifying code. Be a lazy senior dev: question if the code needs to exist at all, prefer stdlib/platform/built-in over new code, delete over add, one-line over many, boring over clever, fewest files possible. Mark intentional shortcuts with `ponytail:` comment.",
    "Use the task tool for subagents. Without overrides it runs the configured model, then openai/gpt-5.5, then opencode/big-pickle. Pass model for a preferred first attempt. Pass models for an exact ordered chain with no implicit fallbacks; encode every user-specified model order or provider restriction there and never add an unrequested provider."
  ],
  "command": {
    "quota": {
      "description": "Show OpenCode quota",
      "agent": "answer",
      "template": "Return this output verbatim. Do not add analysis.\n\n!`node {env:HOME}/.local/share/my-opencode-config/deps/opencode-quota/dist/bin/opencode-quota.js show`"
    },
    "quota_status": {
      "description": "Show OpenCode quota diagnostics",
      "agent": "build",
      "template": "Call the `quota_status` tool with no arguments and return its output verbatim. Do not call other tools."
    }
  },
  "default_agent": "build",
  "permission": {
    "external_directory": {
      "*": "ask",
      "/private/tmp/**": "allow",
      "/tmp/**": "allow",
      "~/.aws/**": "ask",
      "~/.cache/pip/**": "allow",
      "~/.cargo/registry/**": "allow",
      "~/.config/opencode/**": "allow",
      "~/.gitconfig": "allow",
      "~/.gitignore_global": "allow",
      "~/.nvm/**": "allow",
      "~/.npm/**": "allow",
      "~/.opencode/**": "allow",
      "~/.pyenv/**": "allow",
      "~/.rustup/**": "allow",
      "~/.ssh/**": "ask",
      "~/Desktop/Obsidian/**": "allow",
      "~/go/pkg/mod/**": "allow",
      "~/Library/Caches/pip/**": "allow"
    },
    "edit": {
      "*": "deny"
    },
    "bash": {
      "*": "deny",
      "bat *": "allow",
      "cat *": "allow",
      "cmp *": "allow",
      "date": "allow",
      "df -h *": "allow",
      "diff *": "allow",
      "du -sh *": "allow",
      "env": "allow",
      "fd *": "allow",
      "file *": "allow",
      "find *": "allow",
      "find *-delete*": "deny",
      "find *-exec*": "deny",
      "find *-ok*": "deny",
      "find *-fprint*": "deny",
      "find *-fls*": "deny",
      "git blame*": "allow",
      "git branch": "allow",
      "git branch --all*": "allow",
      "git branch --list*": "allow",
      "git branch --show-current*": "allow",
      "git branch -a*": "allow",
      "git branch -r*": "allow",
      "git config --list": "allow",
      "git diff*": "allow",
      "git diff-tree*": "allow",
      "git ls-files*": "allow",
      "git log*": "allow",
      "git merge-base*": "allow",
      "git remote": "allow",
      "git remote -v*": "allow",
      "git remote get-url*": "allow",
      "git rev-parse*": "allow",
      "git show*": "allow",
      "git stash list*": "allow",
      "git stash show*": "allow",
      "git status*": "allow",
      "git tag --list*": "allow",
      "grep *": "allow",
      "head *": "allow",
      "jq *": "allow",
      "less *": "allow",
      "ls*": "allow",
      "lsof *": "allow",
      "ps *": "allow",
      "pwd": "allow",
      "realpath *": "allow",
      "rg *": "allow",
      "stat *": "allow",
      "tail *": "allow",
      "tar -tvf *": "allow",
      "tree *": "allow",
      "uname *": "allow",
      "unzip -l *": "allow",
      "wc *": "allow",
      "which*": "allow",
      "whoami": "allow",
      "xxd *": "allow",
      "command -v *": "allow",
      "gh --version*": "allow",
      "gh help*": "allow",
      "gh auth status*": "allow",
      "gh issue list*": "allow",
      "gh issue status*": "allow",
      "gh issue view*": "allow",
      "gh pr checks*": "allow",
      "gh pr diff*": "allow",
      "gh pr list*": "allow",
      "gh pr status*": "allow",
      "gh pr view*": "allow",
      "gh repo list*": "allow",
      "gh repo view*": "allow",
      "gh repo read-dir*": "allow",
      "gh repo read-file*": "allow",
      "gh run list*": "allow",
      "gh run view*": "allow",
      "gh workflow list*": "allow",
      "gh workflow view*": "allow",
      "gh release list*": "allow",
      "gh release view*": "allow",
      "gh search code*": "allow",
      "gh search commits*": "allow",
      "gh search issues*": "allow",
      "gh search prs*": "allow",
      "gh search repos*": "allow",
      "gh label list*": "allow",
      "gh api *": "allow",
      "gh api graphql*": "deny",
      "gh api *graphql*": "deny",
      "gh api *-X POST*": "deny",
      "gh api *-X PUT*": "deny",
      "gh api *-X PATCH*": "deny",
      "gh api *-X DELETE*": "deny",
      "gh api *-XPOST*": "deny",
      "gh api *-XPUT*": "deny",
      "gh api *-XPATCH*": "deny",
      "gh api *-XDELETE*": "deny",
      "gh api *--method POST*": "deny",
      "gh api *--method PUT*": "deny",
      "gh api *--method PATCH*": "deny",
      "gh api *--method DELETE*": "deny",
      "gh api *--method=POST*": "deny",
      "gh api *--method=PUT*": "deny",
      "gh api *--method=PATCH*": "deny",
      "gh api *--method=DELETE*": "deny",
      "gh api *-f *": "deny",
      "gh api *-F *": "deny",
      "gh api *-f*": "deny",
      "gh api *-F*": "deny",
      "gh api *--field*": "deny",
      "gh api *--raw-field*": "deny",
      "gh api *--input*": "deny",
      "gh api *-H *": "deny",
      "gh api *-H*": "deny",
      "gh api *--header*": "deny"
    }
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "model": "openai/gpt-5.6-sol"
    },
    "build": {
      "mode": "primary",
      "model": "openai/gpt-5.6-terra",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm *": "ask",
          "dd *": "ask"
        }
      }
    },
    "coder": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-luna",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm *": "ask",
          "dd *": "ask"
        }
      }
    },
    "explore": {
      "mode": "subagent",
      "model": "opencode/big-pickle"
    },
    "general": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-terra",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm *": "ask",
          "dd *": "ask"
        }
      }
    },
    "fixer": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-luna",
      "permission": {
        "doom_loop": "deny",
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm *": "ask",
          "dd *": "ask"
        }
      }
    }
  },
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking@2026.7.4"
      ]
    },
    "btca": {
      "type": "local",
      "command": ["btca", "mcp"],
      "timeout": 300000
    },
    "headroom": {
      "type": "local",
      "command": ["headroom", "mcp", "serve"],
      "environment": {
        "HEADROOM_OUTPUT_SHAPER": "1"
      }
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@0.0.78", "--caps=devtools"],
      "enabled": true,
      "timeout": 30000
    },
    "searxng": {
      "type": "local",
      "command": ["npx", "-y", "mcp-searxng@1.11.1"],
      "environment": {
        "SEARXNG_URL": "http://localhost:8080"
      },
      "enabled": true,
      "timeout": 30000
    },
    "vidext-operator-my-workspace": {
      "type": "remote",
      "url": "http://localhost:3000/api/mcp/operator"
    },
    "vidext-operator-staging": {
      "type": "remote",
      "url": "https://staging.vidext.com/api/mcp/operator",
      "enabled": true
    }
  },
  "experimental": { "mcp_timeout": 60000 }
}
