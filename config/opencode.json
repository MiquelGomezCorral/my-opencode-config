{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "{env:HOME}/.local/share/my-opencode-config/deps/opencode-quota/dist/index.js",
    "opencode-queue@0.11.2",
    "{env:HOME}/.config/opencode/plugins/ponytail/.opencode/plugins/ponytail.mjs",
    "{env:HOME}/.config/opencode/plugins/vault-context/vault-context.js"
  ],
  "model": "openai/gpt-5.6-terra",
  "small_model": "openai/gpt-5.5",
  "instructions": [
    "Always respond in English unless the user explicitly asks for another language, even if code, markdown, or skill instructions use a different language.",
    "~/.config/opencode/security-rules.md",
    "~/.config/opencode/surgical-rules.md",
    "Always load the ponytail skill before writing or modifying code. Be a lazy senior dev: question if the code needs to exist at all, prefer stdlib/platform/built-in over new code, delete over add, one-line over many, boring over clever, fewest files possible. Mark intentional shortcuts with `ponytail:` comment.",
    "Use the task tool for subagents. Without overrides it runs the configured model, then openai/gpt-5.5, then opencode/big-pickle. Pass model for a preferred first attempt. Pass models for an exact ordered chain with no implicit fallbacks; encode every user-specified model order or provider restriction there and never add an unrequested provider."
  ],
  "command": {
    "quota": {
      "description": "Show OpenCode quota",
      "agent": "answer",
      "template": "Return this output verbatim. Do not add analysis.\n\n!`node {env:HOME}/.local/share/my-opencode-config/deps/opencode-quota/dist/bin/opencode-quota.js show`"
    },
    "quota_status": {
      "description": "Show OpenCode quota diagnostics",
      "agent": "build",
      "template": "Call the `quota_status` tool with no arguments and return its output verbatim. Do not call other tools."
    }
  },
  "default_agent": "build",
  "permission": {
    "external_directory": {
      "*": "ask",
      "/private/tmp/**": "allow",
      "/tmp/**": "allow",
      "~/.aws/**": "ask",
      "~/.cache/pip/**": "allow",
      "~/.cargo/registry/**": "allow",
      "~/.config/opencode/**": "allow",
      "~/.gitconfig": "allow",
      "~/.gitignore_global": "allow",
      "~/.nvm/**": "allow",
      "~/.npm/**": "allow",
      "~/.opencode/**": "allow",
      "~/.pyenv/**": "allow",
      "~/.rustup/**": "allow",
      "~/.ssh/**": "ask",
      "~/Desktop/Obsidian/**": "allow",
      "~/go/pkg/mod/**": "allow",
      "~/Library/Caches/pip/**": "allow"
    },
    "edit": {
      "*": "ask"
    },
    "bash": {
      "*": "ask",
      "bat *": "allow",
      "black --check *": "allow",
      "bun --version": "allow",
      "bun run *": "allow",
      "bunx *": "allow",
      "cargo --version": "allow",
      "cargo tree *": "allow",
      "cat *": "allow",
      "cmp *": "allow",
      "conda info": "allow",
      "conda list *": "allow",
      "curl *": "allow",
      "date": "allow",
      "df -h *": "allow",
      "diff *": "allow",
      "docker compose config": "allow",
      "docker compose images": "allow",
      "docker compose logs *": "allow",
      "docker compose ps": "allow",
      "docker compose top": "allow",
      "docker compose version": "allow",
      "docker container *": "allow",
      "docker images": "allow",
      "docker info": "allow",
      "docker inspect *": "allow",
      "docker logs *": "allow",
      "docker network ls": "allow",
      "docker ps*": "allow",
      "docker stats *": "allow",
      "docker system *": "allow",
      "docker version": "allow",
      "docker volume ls": "allow",
      "du -sh *": "allow",
      "echo *": "allow",
      "env": "allow",
      "fd *": "allow",
      "file *": "allow",
      "find *": "allow",
      "flake8 *": "allow",
      "git blame*": "allow",
      "git branch*": "allow",
      "git config --list": "allow",
      "git diff*": "allow",
      "git fetch*": "allow",
      "git log*": "allow",
      "git remote*": "allow",
      "git rev-parse *": "allow",
      "git show*": "allow",
      "git status*": "allow",
      "git tag *": "allow",
      "go env": "allow",
      "go list *": "allow",
      "go mod graph": "allow",
      "go version": "allow",
      "grep *": "allow",
      "head *": "allow",
      "jq *": "allow",
      "la *": "allow",
      "less *": "allow",
      "ll *": "allow",
      "ls *": "allow",
      "lsof *": "allow",
      "make -n *": "allow",
      "mypy *": "allow",
      "node -v": "allow",
      "npm list *": "allow",
      "npm run": "allow",
      "npm view *": "allow",
      "open *": "allow",
      "pip list": "allow",
      "pip show *": "allow",
      "pnpm list *": "allow",
      "poetry env info": "allow",
      "poetry show *": "allow",
      "ps *": "allow",
      "pwd": "allow",
      "python -V": "allow",
      "python -m site": "allow",
      "python --version": "allow",
      "python *": "allow",
      "python3 *": "allow",
      "rg *": "allow",
      "rustc --version": "allow",
      "stat *": "allow",
      "system_profiler SPSoftwareDataType": "allow",
      "tail *": "allow",
      "tar -tvf *": "allow",
      "tree *": "allow",
      "tsc --noEmit *": "allow",
      "uname *": "allow",
      "unzip -l *": "allow",
      "wc *": "allow",
      "which *": "allow",
      "whoami": "allow",
      "xxd *": "allow",
      "yarn info *": "allow",
      "yarn list *": "allow"
    }
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "model": "openai/gpt-5.6-sol",
      "permission": {
        "edit": "deny",
        "bash": {
          "gh *": "deny",
          "gh --version*": "allow",
          "gh help*": "allow",
          "gh auth status*": "allow",
          "gh issue list*": "allow",
          "gh issue status*": "allow",
          "gh issue view*": "allow",
          "gh pr checks*": "allow",
          "gh pr diff*": "allow",
          "gh pr list*": "allow",
          "gh pr status*": "allow",
          "gh pr view*": "allow",
          "gh repo list*": "allow",
          "gh repo view*": "allow",
          "gh repo read-dir*": "allow",
          "gh repo read-file*": "allow",
          "gh run list*": "allow",
          "gh run view*": "allow",
          "gh run watch*": "allow",
          "gh workflow list*": "allow",
          "gh workflow view*": "allow",
          "gh release list*": "allow",
          "gh release view*": "allow",
          "gh search code*": "allow",
          "gh search commits*": "allow",
          "gh search issues*": "allow",
          "gh search prs*": "allow",
          "gh search repos*": "allow"
        }
      }
    },
    "build": {
      "mode": "primary",
      "model": "openai/gpt-5.6-terra",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm *": "ask",
          "dd *": "ask"
        }
      }
    },
    "coder": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-luna",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm *": "ask",
          "dd *": "ask"
        }
      }
    },
    "explore": {
      "mode": "subagent",
      "model": "opencode/big-pickle"
    },
    "general": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-terra",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm *": "ask",
          "dd *": "ask"
        }
      }
    },
    "fixer": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-luna",
      "permission": {
        "doom_loop": "deny"
      }
    }
  },
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking@2026.7.4"
      ]
    },
    "btca": {
      "type": "local",
      "command": ["btca", "mcp"],
      "timeout": 300000
    },
    "headroom": {
      "type": "local",
      "command": ["headroom", "mcp", "serve"],
      "environment": {
        "HEADROOM_OUTPUT_SHAPER": "1"
      }
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@0.0.78", "--caps=devtools"],
      "enabled": true,
      "timeout": 30000
    },
    "searxng": {
      "type": "local",
      "command": ["npx", "-y", "mcp-searxng@1.11.1"],
      "environment": {
        "SEARXNG_URL": "http://localhost:8080"
      },
      "enabled": true,
      "timeout": 30000
    },
    "vidext-operator-my-workspace": {
      "type": "remote",
      "url": "http://localhost:3000/api/mcp/operator"
    },
    "vidext-operator-staging": {
      "type": "remote",
      "url": "https://staging.vidext.com/api/mcp/operator",
      "enabled": true
    }
  },
  "experimental": { "mcp_timeout": 60000 }
}
